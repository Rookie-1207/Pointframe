<Window x:Class="Pointframe.BeautifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Pointframe"
        xmlns:models="clr-namespace:Pointframe.Models"
        Title="Screenshot Beautifier — Pointframe"
        Width="940" Height="600"
        MinWidth="700" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        ShowInTaskbar="True">

  <Window.Resources>

    <local:EnumEqualityConverter x:Key="EnumEq"/>

    <!-- Checkerboard for transparent-background preview -->
    <DrawingBrush x:Key="CheckerboardBrush" TileMode="Tile"
                  Viewport="0,0,16,16" ViewportUnits="Absolute">
      <DrawingBrush.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#AAAAAA">
            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,16,16"/></GeometryDrawing.Geometry>
          </GeometryDrawing>
          <GeometryDrawing Brush="#888888">
            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,8,8"/></GeometryDrawing.Geometry>
          </GeometryDrawing>
          <GeometryDrawing Brush="#888888">
            <GeometryDrawing.Geometry><RectangleGeometry Rect="8,8,8,8"/></GeometryDrawing.Geometry>
          </GeometryDrawing>
        </DrawingGroup>
      </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Preset gradient brushes -->
    <LinearGradientBrush x:Key="SunsetBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#F97316" Offset="0"/>
      <GradientStop Color="#EC4899" Offset="0.5"/>
      <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OceanBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#0EA5E9" Offset="0"/>
      <GradientStop Color="#06B6D4" Offset="0.5"/>
      <GradientStop Color="#10B981" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ForestBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#166534" Offset="0"/>
      <GradientStop Color="#15803D" Offset="0.5"/>
      <GradientStop Color="#4ADE80" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LavenderBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#7C3AED" Offset="0"/>
      <GradientStop Color="#A78BFA" Offset="0.5"/>
      <GradientStop Color="#C084FC" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SlateBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#334155" Offset="0"/>
      <GradientStop Color="#475569" Offset="0.5"/>
      <GradientStop Color="#64748B" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="RoseBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#BE123C" Offset="0"/>
      <GradientStop Color="#F43F5E" Offset="0.5"/>
      <GradientStop Color="#FB923C" Offset="1"/>
    </LinearGradientBrush>

    <!-- Preset swatch RadioButton -->
    <Style x:Key="SwatchBtn" TargetType="RadioButton">
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Margin" Value="2"/>
      <Setter Property="GroupName" Value="BgPreset"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Outer" CornerRadius="6" BorderThickness="2" BorderBrush="Transparent">
              <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsMouseOver" Value="True"/>
                  <Condition Property="IsChecked" Value="False"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Section heading -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource MutedText}"/>
      <Setter Property="Margin" Value="0,10,0,5"/>
    </Style>

    <!-- Slider row label -->
    <Style x:Key="SliderLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Width" Value="68"/>
    </Style>

    <!-- Slider value readout -->
    <Style x:Key="SliderValue" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Width" Value="38"/>
      <Setter Property="TextAlignment" Value="Right"/>
      <Setter Property="FontFamily" Value="Consolas"/>
    </Style>

    <!-- Primary export button -->
    <Style x:Key="ExportBtn" TargetType="Button">
      <Setter Property="Height" Value="36"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{DynamicResource AccentColor}" CornerRadius="5">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Secondary button -->
    <Style x:Key="SecondaryBtn" TargetType="Button">
      <Setter Property="Height" Value="30"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{DynamicResource ControlBackground}"
                    BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackground}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PressedBackground}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Toggle switch for shadow enable/disable -->
    <Style x:Key="ToggleBtn" TargetType="ToggleButton">
      <Setter Property="Width" Value="40"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Track" Background="{DynamicResource ControlBorder}" CornerRadius="11" Padding="2">
              <Border x:Name="Thumb" Width="18" Height="18" CornerRadius="9"
                      Background="{DynamicResource SurfaceBackground}"
                      HorizontalAlignment="Left"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentColor}"/>
                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                <Setter TargetName="Thumb" Property="Background" Value="White"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="270"/>
    </Grid.ColumnDefinitions>

    <!-- ── Left panel: preview ── -->
    <Grid Grid.Column="0" Background="{StaticResource CheckerboardBrush}" ClipToBounds="True">

      <!-- Live preview -->
      <Viewbox Stretch="Uniform" Margin="16"
               HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Background="{Binding BackgroundBrush}"
                Width="{Binding CanvasPixelWidth}"
                Height="{Binding CanvasPixelHeight}"
                SnapsToDevicePixels="True">
          <Grid>
            <!-- Shadow wrapper — not clipped, so shadow renders into padding area -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="{Binding PaddingThickness}">
              <Border.Effect>
                <DropShadowEffect BlurRadius="{Binding ShadowBlur}"
                                  ShadowDepth="{Binding ShadowOffsetY}"
                                  Opacity="{Binding EffectiveShadowOpacity}"
                                  Direction="270" Color="Black"/>
              </Border.Effect>
              <Border Width="{Binding SourceBitmap.PixelWidth}"
                      Height="{Binding SourceBitmap.PixelHeight}"
                      CornerRadius="{Binding ScreenshotCornerRadius}">
                <Border.Background>
                  <ImageBrush ImageSource="{Binding SourceBitmap}" Stretch="Fill"/>
                </Border.Background>
              </Border>
            </Border>
          </Grid>
        </Border>
      </Viewbox>

      <!-- Toast notification (shown briefly on export/copy) -->
      <Border x:Name="Toast"
              Background="#DD333333" CornerRadius="6" Padding="14,7"
              HorizontalAlignment="Center" VerticalAlignment="Top"
              Margin="0,14,0,0" Visibility="Collapsed">
        <TextBlock x:Name="ToastText"
                   Foreground="White" FontSize="12"
                   FontFamily="Segoe UI" FontWeight="SemiBold"/>
      </Border>

    </Grid>

    <!-- ── Right panel: controls ── -->
    <Border Grid.Column="1"
            Background="{DynamicResource SurfaceBackground}"
            BorderBrush="{DynamicResource SurfaceBorder}"
            BorderThickness="1,0,0,0">
      <DockPanel>

        <!-- Sidebar header -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="0,0,0,1"
                Padding="14,9">
          <Grid>
            <TextBlock Text="Beautifier"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryText}"
                       VerticalAlignment="Center"/>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding CloseCommand}" Width="22" Height="22"
                    Cursor="Hand" ToolTip="Close">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                               FontSize="10" Foreground="{DynamicResource MutedText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackground}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </Grid>
        </Border>

        <!-- CTA buttons pinned to bottom -->
        <StackPanel DockPanel.Dock="Bottom" Margin="12,8,12,12">
          <Button Style="{StaticResource ExportBtn}" Command="{Binding ExportCommand}" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                         Foreground="White" VerticalAlignment="Center" Margin="0,0,7,0"/>
              <TextBlock Text="Export Image" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource SecondaryBtn}" Command="{Binding CopyToClipboardCommand}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                         Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"
                         Margin="0,0,6,0"/>
              <TextBlock Text="Copy to Clipboard"
                         Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Scrollable settings -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="12,4,12,4">
          <StackPanel>

            <!-- Background presets -->
            <TextBlock Text="BACKGROUND" Style="{StaticResource SectionLabel}"/>
            <UniformGrid Columns="4" Margin="0,0,0,6">

              <RadioButton Style="{StaticResource SwatchBtn}" Background="{StaticResource SunsetBrush}" ToolTip="Sunset"
                           Command="{Binding SelectBackgroundCommand}" CommandParameter="{x:Static models:BeautifyBackground.Sunset}">
                <RadioButton.IsChecked>
                  <Binding Path="SelectedBackground" Converter="{StaticResource EnumEq}" ConverterParameter="{x:Static models:BeautifyBackground.Sunset}"/>
                </RadioButton.IsChecked>
              </RadioButton>

              <RadioButton Style="{StaticResource SwatchBtn}" Background="{StaticResource OceanBrush}" ToolTip="Ocean"
                           Command="{Binding SelectBackgroundCommand}" CommandParameter="{x:Static models:BeautifyBackground.Ocean}">
                <RadioButton.IsChecked>
                  <Binding Path="SelectedBackground" Converter="{StaticResource EnumEq}" ConverterParameter="{x:Static models:BeautifyBackground.Ocean}"/>
                </RadioButton.IsChecked>
              </RadioButton>

              <RadioButton Style="{StaticResource SwatchBtn}" Background="{StaticResource ForestBrush}" ToolTip="Forest"
                           Command="{Binding SelectBackgroundCommand}" CommandParameter="{x:Static models:BeautifyBackground.Forest}">
                <RadioButton.IsChecked>
                  <Binding Path="SelectedBackground" Converter="{StaticResource EnumEq}" ConverterParameter="{x:Static models:BeautifyBackground.Forest}"/>
                </RadioButton.IsChecked>
              </RadioButton>

              <RadioButton Style="{StaticResource SwatchBtn}" Background="{StaticResource LavenderBrush}" ToolTip="Lavender"
                           Command="{Binding SelectBackgroundCommand}" CommandParameter="{x:Static models:BeautifyBackground.Lavender}">
                <RadioButton.IsChecked>
                  <Binding Path="SelectedBackground" Converter="{StaticResource EnumEq}" ConverterParameter="{x:Static models:BeautifyBackground.Lavender}"/>
                </RadioButton.IsChecked>
              </RadioButton>

              <RadioButton Style="{StaticResource SwatchBtn}" Background="{StaticResource SlateBrush}" ToolTip="Slate"
                           Command="{Binding SelectBackgroundCommand}" CommandParameter="{x:Static models:BeautifyBackground.Slate}">
                <RadioButton.IsChecked>
                  <Binding Path="SelectedBackground" Converter="{StaticResource EnumEq}" ConverterParameter="{x:Static models:BeautifyBackground.Slate}"/>
                </RadioButton.IsChecked>
              </RadioButton>

              <RadioButton Style="{StaticResource SwatchBtn}" Background="{StaticResource RoseBrush}" ToolTip="Rose"
                           Command="{Binding SelectBackgroundCommand}" CommandParameter="{x:Static models:BeautifyBackground.Rose}">
                <RadioButton.IsChecked>
                  <Binding Path="SelectedBackground" Converter="{StaticResource EnumEq}" ConverterParameter="{x:Static models:BeautifyBackground.Rose}"/>
                </RadioButton.IsChecked>
              </RadioButton>

              <RadioButton Style="{StaticResource SwatchBtn}" ToolTip="White"
                           Command="{Binding SelectBackgroundCommand}" CommandParameter="{x:Static models:BeautifyBackground.White}">
                <RadioButton.Background><SolidColorBrush Color="#F8FAFC"/></RadioButton.Background>
                <RadioButton.IsChecked>
                  <Binding Path="SelectedBackground" Converter="{StaticResource EnumEq}" ConverterParameter="{x:Static models:BeautifyBackground.White}"/>
                </RadioButton.IsChecked>
              </RadioButton>

              <RadioButton Style="{StaticResource SwatchBtn}" Background="{StaticResource CheckerboardBrush}" ToolTip="Transparent (PNG)"
                           Command="{Binding SelectBackgroundCommand}" CommandParameter="{x:Static models:BeautifyBackground.None}">
                <RadioButton.IsChecked>
                  <Binding Path="SelectedBackground" Converter="{StaticResource EnumEq}" ConverterParameter="{x:Static models:BeautifyBackground.None}"/>
                </RadioButton.IsChecked>
              </RadioButton>

            </UniformGrid>

            <!-- Frame -->
            <TextBlock Text="FRAME" Style="{StaticResource SectionLabel}"/>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Padding" Style="{StaticResource SliderLabel}"/>
              <Slider Grid.Column="1" Minimum="0" Maximum="120" Value="{Binding Padding}" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0:0}px"><Binding Path="Padding"/></MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </Grid>

            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Corners" Style="{StaticResource SliderLabel}"/>
              <Slider Grid.Column="1" Minimum="0" Maximum="40" Value="{Binding CornerRadius}" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0:0}px"><Binding Path="CornerRadius"/></MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </Grid>

            <!-- Shadow -->
            <TextBlock Text="SHADOW" Style="{StaticResource SectionLabel}"/>

            <Grid Margin="0,0,0,8">
              <TextBlock Text="Drop shadow" Style="{StaticResource SliderLabel}" Width="Auto" VerticalAlignment="Center"/>
              <ToggleButton HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource ToggleBtn}" IsChecked="{Binding ShadowEnabled}"/>
            </Grid>

            <StackPanel>
              <StackPanel.Style>
                <Style TargetType="StackPanel">
                  <Setter Property="Opacity" Value="1"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding ShadowEnabled}" Value="False">
                      <Setter Property="Opacity" Value="0.35"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </StackPanel.Style>

              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Blur" Style="{StaticResource SliderLabel}"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="80" Value="{Binding ShadowBlur}"
                        IsEnabled="{Binding ShadowEnabled}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:0}px"><Binding Path="ShadowBlur"/></MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </Grid>

              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Offset" Style="{StaticResource SliderLabel}"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="60" Value="{Binding ShadowOffsetY}"
                        IsEnabled="{Binding ShadowEnabled}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:0}px"><Binding Path="ShadowOffsetY"/></MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </Grid>

              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Opacity" Style="{StaticResource SliderLabel}"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding ShadowOpacity}"
                        IsEnabled="{Binding ShadowEnabled}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Style="{StaticResource SliderValue}">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:P0}"><Binding Path="ShadowOpacity"/></MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </Grid>

            </StackPanel>

          </StackPanel>
        </ScrollViewer>

      </DockPanel>
    </Border>

  </Grid>
</Window>
